{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "ui_kits/tooldex/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Grotesk|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Space Grotesk, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|className|style|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, className, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:neutral|blue|orange)$/]",
        "message": "<Badge> variant must be one of 'neutral' | 'blue' | 'orange'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|action|className|style|children|key|ref|className|style|children)$/]",
        "message": "<Banner> doesn't accept that prop. Declared props: tone, icon, action, className, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:info|warn|error)$/]",
        "message": "<Banner> tone must be one of 'info' | 'warn' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|type|onClick|className|style|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, type, onClick, className, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger|success|orange)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger' | 'success' | 'orange'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:as|className|style|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: as, className, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|active|onClick|className|style|children|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: variant, active, onClick, className, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:filter|type)$/]",
        "message": "<Chip> variant must be one of 'filter' | 'type'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|children|href|title|onClick|material|isoGroup|color|style|key|ref|className|style|children)$/]",
        "message": "<DataBadge> doesn't accept that prop. Declared props: kind, children, href, title, onClick, material, isoGroup, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataBadge'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:description|proshop|holder|machine|location|preset|no-fusion)$/]",
        "message": "<DataBadge> kind must be one of 'description' | 'proshop' | 'holder' | 'machine' | 'location' | 'preset' | 'no-fusion'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataBadge'] > JSXAttribute[name.name='isoGroup'] > Literal[value!=/^(?:P|M|K|N|S|H)$/]",
        "message": "<DataBadge> isoGroup must be one of 'P' | 'M' | 'K' | 'N' | 'S' | 'H'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|disabled|title|onClick|className|style|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: active, disabled, title, onClick, className, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|required|error|hint|type|value|onChange|placeholder|disabled|className|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, required, error, hint, type, value, onChange, placeholder, disabled, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|onClear|placeholder|autoFocus|className|style|key|ref|className|style|children)$/]",
        "message": "<SearchBar> doesn't accept that prop. Declared props: value, onChange, onClear, placeholder, autoFocus, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedToggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|className|style|key|ref|className|style|children)$/]",
        "message": "<SegmentedToggle> doesn't accept that prop. Declared props: options, value, onChange, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|required|value|onChange|options|disabled|className|style|children|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: label, required, value, onChange, options, disabled, className, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Spinner'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|borderWidth|className|style|key|ref|className|style|children)$/]",
        "message": "<Spinner> doesn't accept that prop. Declared props: size, borderWidth, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|message|onDismiss|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: type, message, onDismiss."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:success|error|info)$/]",
        "message": "<Toast> type must be one of 'success' | 'error' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tool'] > JSXAttribute > JSXIdentifier[name!=/^(?:tool_type|type|description|location|proshop_id|machine_tool_number|diameter|number_of_flutes|flute_length|vendor|coating|preferred_machine|unit|key|ref|className|style|children)$/]",
        "message": "<Tool> doesn't accept that prop. Declared props: tool_type, type, description, location, proshop_id, machine_tool_number, diameter, number_of_flutes, flute_length, vendor, coating, preferred_machine, unit."
      },
      {
        "selector": "JSXOpeningElement[name.name='ToolTypeIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|size|strokeWidth|className|style|key|ref|className|style|children)$/]",
        "message": "<ToolTypeIcon> doesn't accept that prop. Declared props: type, size, strokeWidth, className, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
