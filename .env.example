# ─── Autodesk Platform Services (APS) — Fusion tool library ──────────────────
# Create a "Single Page App" at https://aps.autodesk.com (enables PKCE, no secret)
VITE_APS_CLIENT_ID=your_aps_client_id_here
# Must EXACTLY match a callback URL registered on your APS app, incl. trailing slash.
# Local:  http://localhost:5173/Master_Tool_Data/
# Pages:  https://yourusername.github.io/Master_Tool_Data/
VITE_APS_CALLBACK_URL=https://yourusername.github.io/Master_Tool_Data/

# ─── Google — tool_metadata.json only ────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
VITE_METADATA_FILE_ID=google_drive_file_id_for_tool_metadata_json
